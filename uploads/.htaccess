# Seguridad: nunca ejecutar código dentro de /uploads
<FilesMatch "\.(php|php\d|phtml|pl|py|cgi|sh)$">
    Require all denied
</FilesMatch>
Options -Indexes -ExecCGI
RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .php8
RemoveType .php .phtml
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
